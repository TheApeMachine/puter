// x86 int4 (packed nibble) dequant helpers: nibble unpack, sign-extend, f32 scale.

DATA dequantInt4Mask0F<>+0(SB)/8, $0x0F0F0F0F0F0F0F0F
GLOBL dequantInt4Mask0F<>(SB), RODATA, $8

#define INT4_UNPACK_NIBBLES_SSE2_X0 \
	VPAND X7, X0, X1; \
	VPUNPCKLBW X1, X6, X1; \
	VPSLLW $12, X1, X1; \
	VPSRAW $12, X1, X1; \
	VPUNPCKLBW X0, X6, X2; \
	VPSRLW $4, X2, X2; \
	VPSLLW $12, X2, X2; \
	VPSRAW $12, X2, X2

#define INT4_UNPACK_NIBBLES_ZXBW_X0 \
	VPAND X7, X0, X1; \
	VPMOVZXBW X1, X1; \
	VPSLLW $12, X1, X1; \
	VPSRAW $12, X1, X1; \
	VPMOVZXBW X0, X2; \
	VPSRLW $4, X2, X2; \
	VPSLLW $12, X2, X2; \
	VPSRAW $12, X2, X2

#define INT4_INTERLEAVE_W16_X3_X4 \
	VPUNPCKLWD X1, X2, X3; \
	VPUNPCKHWD X1, X2, X4

#define INT4_SSE2_SXW_TO_I32_X3 \
	VPUNPCKLWD X3, X3, X1; \
	VPSRAD $16, X1, X1; \
	VPUNPCKHWD X3, X3, X2; \
	VPSRAD $16, X2, X2; \
	MOVLHPS X2, X1

#define INT4_SSE2_SXW_TO_I32_X4 \
	VPUNPCKLWD X4, X4, X1; \
	VPSRAD $16, X1, X1; \
	VPUNPCKHWD X4, X4, X2; \
	VPSRAD $16, X2, X2; \
	MOVLHPS X2, X1

#define INT4_SSE2_DEQUANT_XMM_X1 \
	VPSUBD X14, X1, X1; \
	VCVTDQ2PS X1, X1; \
	VMULPS X15, X1, X1; \
	VMOVUPS X1, (DI)

#define INT4_SSE2_DEQUANT_XMM_X1_OFFS(off) \
	VPSUBD X14, X1, X1; \
	VCVTDQ2PS X1, X1; \
	VMULPS X15, X1, X1; \
	VMOVUPS X1, off(DI)

#define INT4_AVX_DEQUAT_Y5_Y6 \
	VPMOVSXBD X3, Y5; \
	VPMOVSXBD X4, Y6; \
	VPSUBD Y5, Y14, Y5; \
	VPSUBD Y6, Y14, Y6; \
	VCVTDQ2PS Y5, Y5; \
	VCVTDQ2PS Y6, Y6; \
	VMULPS Y5, Y15, Y5; \
	VMULPS Y6, Y15, Y6; \
	VMOVUPS Y5, (DI); \
	VMOVUPS Y6, 32(DI)
