#ifndef PUTER_DEVICE_METAL_LAYERNORM_APPLY_METALINC
#define PUTER_DEVICE_METAL_LAYERNORM_APPLY_METALINC

template <typename Storage, typename Scalar>
static inline void layernorm_apply_row(
    device const Scalar* input,
    device const Scalar* scale,
    device const Scalar* bias,
    device Scalar* out,
    uint rowOffset,
    constant uint& cols,
    float mean,
    float invStdDev,
    uint threadIndex
) {
    uint vectorStride = normalizationThreadCount * 4;
    float4 meanVec = float4(mean);
    float4 invStdDevVec = float4(invStdDev);

    for (uint col = threadIndex * 4; col < cols; col += vectorStride) {
        if (col + 4 <= cols) {
#pragma METAL fp_contract(off)
            float4 inputValue = float4(
                Storage::load(input, rowOffset + col),
                Storage::load(input, rowOffset + col + 1),
                Storage::load(input, rowOffset + col + 2),
                Storage::load(input, rowOffset + col + 3)
            );
            float4 scaleValue = float4(
                Storage::load(scale, col),
                Storage::load(scale, col + 1),
                Storage::load(scale, col + 2),
                Storage::load(scale, col + 3)
            );
            float4 biasValue = float4(
                Storage::load(bias, col),
                Storage::load(bias, col + 1),
                Storage::load(bias, col + 2),
                Storage::load(bias, col + 3)
            );
            float4 delta = inputValue - meanVec;
            delta = delta * invStdDevVec;
            float4 result = fma(scaleValue, delta, biasValue);
#pragma METAL fp_contract(on)
            Storage::store(out, rowOffset + col, result.x);
            Storage::store(out, rowOffset + col + 1, result.y);
            Storage::store(out, rowOffset + col + 2, result.z);
            Storage::store(out, rowOffset + col + 3, result.w);

            continue;
        }

        for (uint offset = 0; offset < 4; offset++) {
            uint colIndex = col + offset;

            if (colIndex >= cols) {
                break;
            }

#pragma METAL fp_contract(off)
            float inputValue = Storage::load(input, rowOffset + colIndex);
            float scaleValue = Storage::load(scale, colIndex);
            float biasValue = Storage::load(bias, colIndex);
            float delta = inputValue - mean;
            delta = delta * invStdDev;
            float result = fma(scaleValue, delta, biasValue);
#pragma METAL fp_contract(on)
            Storage::store(out, rowOffset + colIndex, result);
        }
    }
}

template <>
inline void layernorm_apply_row<Float16NormStorage, half>(
    device const half* input,
    device const half* scale,
    device const half* bias,
    device half* out,
    uint rowOffset,
    constant uint& cols,
    float mean,
    float invStdDev,
    uint threadIndex
) {
    uint vectorStride = normalizationThreadCount * 4;

    for (uint col = threadIndex * 4; col < cols; col += vectorStride) {
        for (uint offset = 0; offset < 4; offset++) {
            uint colIndex = col + offset;

            if (colIndex >= cols) {
                break;
            }

#pragma METAL fp_contract(off)
            float inputValue = Float16NormStorage::load(input, rowOffset + colIndex);
            float scaleValue = Float16NormStorage::load(scale, colIndex);
            float biasValue = Float16NormStorage::load(bias, colIndex);
            float delta = inputValue - mean;
            delta = delta * invStdDev;
            delta = delta * scaleValue;
            float result = delta + biasValue;
#pragma METAL fp_contract(on)
            Float16NormStorage::store(out, rowOffset + colIndex, result);
        }
    }
}

template <>
inline void layernorm_apply_row<BFloat16NormStorage, ushort>(
    device const ushort* input,
    device const ushort* scale,
    device const ushort* bias,
    device ushort* out,
    uint rowOffset,
    constant uint& cols,
    float mean,
    float invStdDev,
    uint threadIndex
) {
    uint vectorStride = normalizationThreadCount * 4;

    for (uint col = threadIndex * 4; col < cols; col += vectorStride) {
        for (uint offset = 0; offset < 4; offset++) {
            uint colIndex = col + offset;

            if (colIndex >= cols) {
                break;
            }

#pragma METAL fp_contract(off)
            float inputValue = BFloat16NormStorage::load(input, rowOffset + colIndex);
            float scaleValue = BFloat16NormStorage::load(scale, colIndex);
            float biasValue = BFloat16NormStorage::load(bias, colIndex);
            float normalized = (inputValue - mean) * invStdDev;
            float result = normalized * scaleValue + biasValue;
#pragma METAL fp_contract(on)
            BFloat16NormStorage::store(out, rowOffset + colIndex, result);
        }
    }
}

#endif
